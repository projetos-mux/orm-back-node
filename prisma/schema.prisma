// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
  DELETED
}

model Company {
  id         String       @id @default(uuid())
  name       String
  email      String    @unique
  apiKey     String    @unique

  status     Status      @default(ACTIVE)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  users      User[]
  resumes    Resume[]
}

model Resume {
  id            String       @id @default(uuid())
  fileName      String
  fullName      String?
  email         String?
  confidence    Float?
  processingMs  Int?
  costBrl       Float?
  createdAt     DateTime?
  dataJson      String

  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
}

model Role {
  id        String     @id @default(uuid())
  name      String  @unique // admin | mod | recruiter

  users     User[]
}

model User {
  id          String      @id @default(uuid())
  name        String
  email       String   @unique
  password    String

  status      Status   @default(ACTIVE)

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  auditLogsPerformed AuditLog[] @relation("PerformedBy")
}

model AuditLog {
  id                String    @id @default(uuid())

  entityType        String
  entityId          String

  action            String

  oldValue          String?
  newValue          String?

  performedByUserId String
  performedBy       User      @relation("PerformedBy", fields: [performedByUserId], references: [id])

  performedByName   String

  createdAt         DateTime  @default(now())
}